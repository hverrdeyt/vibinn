generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  MANUAL
  GOOGLE
  APPLE
}

enum LocationType {
  CITY
  PROVINCE
  COUNTRY
}

enum Visibility {
  PUBLIC
  PRIVATE
  FOLLOWERS
}

enum VisitType {
  SOLO
  COUPLE
  FRIENDS
  FAMILY
}

enum TimeOfDay {
  MORNING
  AFTERNOON
  SUNSET
  NIGHT
}

enum RevisitIntent {
  YES
  NOT_SURE
  NOT_INTERESTED
}

enum MomentRatingLabel {
  DISLIKED
  NOT_BAD
  LIKED
  RECOMMENDED
}

enum NotificationType {
  PLACE_MATCH
  TRAVELER_OVERLAP
  COMMENT
  VIBIN
  FOLLOW
  CHAT_MESSAGE
  SYSTEM
}

enum TargetType {
  PROFILE
  MOMENT
  PLACE
  PLACE_VISIT
  COLLECTION
  CONVERSATION
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

enum GooglePlaceSnapshotSource {
  TEXT_SEARCH
  PLACE_DETAILS
}

model User {
  id                String               @id @default(cuid())
  username          String               @unique
  displayName       String?
  email             String               @unique
  passwordHash      String?
  appleSubject      String?              @unique
  bio               String
  avatarUrl         String
  authProvider      AuthProvider         @default(MANUAL)
  emailVerifiedAt   DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  badges            UserBadge[]
  flags             UserFlag[]
  savedLocations    UserSavedLocation[]
  preferences       UserPreference?
  accountSettings   UserAccountSettings?
  notificationPrefs UserNotificationSettings?
  privacySettings   UserPrivacySettings?
  bookmarks         Bookmark[]
  dismissedPlaces   DismissedPlace[]
  collections       Collection[]
  moments           Moment[]
  notifications     Notification[]       @relation("NotificationRecipient")
  actors            Notification[]       @relation("NotificationActor")
  comments          Comment[]
  vibinsSent        Vibin[]              @relation("VibinSender")
  vibinsReceived    Vibin[]              @relation("VibinReceiver")
  followsGiven      Follow[]             @relation("FollowSource")
  followsReceived   Follow[]             @relation("FollowTarget")
  friendshipRequestsSent Friendship[]    @relation("FriendshipRequester")
  friendshipRequestsReceived Friendship[] @relation("FriendshipAddressee")
  conversationMemberships ConversationMember[]
  sentChatMessages  ChatMessage[]        @relation("ChatMessageSender")
  directConversationsA Conversation[]    @relation("ConversationDirectUserA")
  directConversationsB Conversation[]    @relation("ConversationDirectUserB")
  blocksGiven       UserBlock[]          @relation("UserBlockSource")
  blocksReceived    UserBlock[]          @relation("UserBlockTarget")
  reportsGiven      UserReport[]         @relation("UserReportReporter")
  reportsReceived   UserReport[]         @relation("UserReportTargetUser")
  travelerScores    TravelerSimilarity[] @relation("TravelerScoreOwner")
  travelerMatches   TravelerSimilarity[] @relation("TravelerScoreMatch")
  placeScores       UserPlaceScore[]
  shares            Share[]
  sessions          Session[]
  devices           UserDevice[]
  decisionSessions  DecisionSession[]
  decisionSaves     DecisionSave[]
  decisionSessionEvents DecisionSessionEvent[]
  decisionCheckinContexts DecisionCheckinContext[]
  decisionFeedUnlocks DecisionFeedUnlock[]
  experimentAssignments ExperimentAssignment[]
  feedPosts         FeedPost[]
}

model Session {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserDevice {
  id         String   @id @default(cuid())
  userId     String
  fcmToken   String   @unique
  platform   String
  appVersion String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  createdAt DateTime @default(now())
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  label     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserFlag {
  id        String   @id @default(cuid())
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique
  selectedInterests   String[]
  selectedVibe        String?
  onboardingCompleted Boolean  @default(false)
  skippedPreferences  Boolean  @default(false)
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserAccountSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserNotificationSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  pushEnabled           Boolean  @default(true)
  emailEnabled          Boolean  @default(true)
  recommendationEnabled Boolean  @default(true)
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPrivacySettings {
  id                String     @id @default(cuid())
  userId            String     @unique
  profileVisibility Visibility @default(PUBLIC)
  momentVisibility  Visibility @default(PUBLIC)
  updatedAt         DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Location {
  id              String              @id @default(cuid())
  name            String
  type            LocationType
  countryCode     String?
  latitude        Float?
  longitude       Float?
  googlePlaceId   String?             @unique
  discoverySeededAt DateTime?
  discoveryLastGoogleSyncAt DateTime?
  discoveryCandidateCount Int         @default(0)
  discoverySeedVersion String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  savedByUsers    UserSavedLocation[]
  places          Place[]
}

model UserSavedLocation {
  id         String   @id @default(cuid())
  userId     String
  locationId String
  sortOrder  Int      @default(0)
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, locationId])
}

model Place {
  id                String             @id @default(cuid())
  googlePlaceId     String?            @unique
  locationId        String?
  name              String
  address           String?
  city              String?
  country           String?
  neighborhood      String?
  adminAreaLevel4   String?
  category          String
  googleDisplayName String?
  shortFormattedAddress String?
  googleTypes       String[]           @default([])
  googlePrimaryType String?
  googlePrimaryTypeDisplayName String?
  googleMapsTypeLabel String?
  businessStatus    String?
  openingDateJson   Json?
  latitude          Float?
  longitude         Float?
  rating            Float?
  userRatingCount   Int?
  priceLevel        Int?
  openingHours      String[]           @default([])
  currentOpeningHours String[]         @default([])
  servesBreakfast   Boolean?
  servesLunch       Boolean?
  servesDinner      Boolean?
  servesBeer        Boolean?
  servesWine        Boolean?
  servesBrunch      Boolean?
  servesDessert     Boolean?
  servesCoffee      Boolean?
  servesCocktails   Boolean?
  servesVegetarianFood Boolean?
  takeout           Boolean?
  delivery          Boolean?
  dineIn            Boolean?
  curbsidePickup    Boolean?
  reservable        Boolean?
  liveMusic         Boolean?
  menuForChildren   Boolean?
  goodForChildren   Boolean?
  allowsDogs        Boolean?
  restroom          Boolean?
  goodForGroups     Boolean?
  goodForWatchingSports Boolean?
  timeZoneId        String?
  utcOffsetMinutes  Int?
  outdoorSeating    Boolean?
  googlePriceRangeStart    Float?
  googlePriceRangeEnd      Float?
  googlePriceRangeCurrency String?
  primaryImageUrl   String?
  mapsEmbedUrl      String?
  websiteUri        String?
  addressComponentsJson Json?
  photosJson        Json?
  reviewsJson       Json?
  paymentOptionsJson Json?
  parkingOptionsJson Json?
  accessibilityOptionsJson Json?
  editorialSummaryJson Json?
  reviewSummaryJson Json?
  generativeSummaryJson Json?
  googleMapsLinksJson Json?
  containingPlacesJson Json?
  firstSeenAt       DateTime           @default(now())
  lastGoogleFetchedAt DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  location          Location?          @relation(fields: [locationId], references: [id], onDelete: SetNull)
  media             PlaceMedia[]
  aiEnrichment      PlaceAiEnrichment?
  traitProfile      PlaceTraitProfile?
  googleSnapshots   PlaceGoogleSnapshot[]
  discoverySignals  PlaceDiscoverySignal[]
  userScores        UserPlaceScore[]
  bookmarks         Bookmark[]
  dismissedByUsers  DismissedPlace[]
  moments           Moment[]
  feedPosts         FeedPost[]
  collectionPlaces  CollectionPlace[]
  decisionSessionOptions DecisionSessionOption[]
  decisionSaves     DecisionSave[]
  decisionSessionEvents DecisionSessionEvent[]
  decisionCheckinContexts DecisionCheckinContext[]
}

model PlaceTraitProfile {
  id                String   @id @default(cuid())
  placeId           String   @unique
  provider          String
  model             String?
  sourceVersion     String
  confidence        Float?
  quietScore        Float
  socialScore       Float
  soloScore         Float
  cozyScore         Float
  workScore         Float
  dateScore         Float
  utilitarianScore  Float
  qualityScore      Float
  quickReadyScore   Float
  stayReadyScore    Float
  budgetFriendlyScore Float
  archetype         String?
  evidenceJson      Json?
  rawResponseJson   Json?
  inputSnapshotJson Json?
  enrichedAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model PlaceDiscoverySignal {
  id                 String   @id @default(cuid())
  placeId            String
  googlePlaceId      String
  source             String   @default("GOOGLE_TEXT_SEARCH")
  queryText          String
  queryType          String?
  preferenceCategory String?
  selectedVibe       String?
  resultRank         Int?
  bestResultRank     Int?
  locationLabel      String?
  locationType       String?
  seenCount          Int      @default(1)
  firstSeenAt        DateTime @default(now())
  lastSeenAt         DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([googlePlaceId, queryText, locationLabel, locationType])
  @@index([placeId])
  @@index([preferenceCategory])
  @@index([queryType])
  @@index([locationLabel, locationType])
  @@index([lastSeenAt])
}

model PlaceGoogleSnapshot {
  id            String                    @id @default(cuid())
  placeId       String
  googlePlaceId String
  source        GooglePlaceSnapshotSource
  queryContext  String?
  payloadJson   Json
  fetchedAt     DateTime                  @default(now())
  createdAt     DateTime                  @default(now())

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId, fetchedAt])
  @@index([googlePlaceId, source, fetchedAt])
}

model PlaceMedia {
  id           String   @id @default(cuid())
  placeId      String
  mediaType    String
  url          String
  thumbnailUrl String?
  source       String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model PlaceAiEnrichment {
  id             String   @id @default(cuid())
  placeId         String   @unique
  hook            String
  description     String?
  vibeTags        String[]
  attitudeLabel   String?
  bestTime        String?
  updatedAt       DateTime @updatedAt

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model UserPlaceScore {
  id                   String   @id @default(cuid())
  userId               String
  placeId              String
  matchScore           Int?
  similarityPercentage Int?
  recommendationReason String
  distanceKm           Float?
  sourceVersion        String?
  updatedAt            DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  placeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
}

model DismissedPlace {
  id        String   @id @default(cuid())
  userId    String
  placeId   String
  reason    String?
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
}

model Follow {
  id         String   @id @default(cuid())
  sourceUserId String
  targetUserId String
  createdAt  DateTime @default(now())

  sourceUser User @relation("FollowSource", fields: [sourceUserId], references: [id], onDelete: Cascade)
  targetUser User @relation("FollowTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([sourceUserId, targetUserId])
}

model Friendship {
  id             String           @id @default(cuid())
  requesterId    String
  addresseeId    String
  status         FriendshipStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  respondedAt    DateTime?

  requester      User             @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee      User             @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
}

model Conversation {
  id             String   @id @default(cuid())
  kind           String   @default("direct")
  directUserAId  String?
  directUserBId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastMessageAt  DateTime?

  directUserA    User?    @relation("ConversationDirectUserA", fields: [directUserAId], references: [id], onDelete: SetNull)
  directUserB    User?    @relation("ConversationDirectUserB", fields: [directUserBId], references: [id], onDelete: SetNull)
  members        ConversationMember[]
  messages       ChatMessage[]

  @@unique([directUserAId, directUserBId])
  @@index([lastMessageAt])
}

model ConversationMember {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  createdAt      DateTime @default(now())
  lastReadAt     DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, createdAt])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderUserId   String
  kind           String   @default("text")
  body           String?
  createdAt      DateTime @default(now())

  conversation   Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser     User                 @relation("ChatMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  attachments    ChatMessageAttachment[]

  @@index([conversationId, createdAt])
  @@index([senderUserId, createdAt])
}

model ChatMessageAttachment {
  id          String     @id @default(cuid())
  messageId    String
  targetType   TargetType
  targetId     String
  momentId     String?
  previewText  String?
  createdAt    DateTime   @default(now())

  message      ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  moment       Moment?     @relation(fields: [momentId], references: [id], onDelete: SetNull)

  @@index([messageId])
  @@index([targetType, targetId])
}

model UserBlock {
  id            String   @id @default(cuid())
  sourceUserId  String
  targetUserId  String
  reason        String?
  createdAt     DateTime @default(now())

  sourceUser User @relation("UserBlockSource", fields: [sourceUserId], references: [id], onDelete: Cascade)
  targetUser User @relation("UserBlockTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([sourceUserId, targetUserId])
}

model UserReport {
  id           String     @id @default(cuid())
  reporterId   String
  targetType   TargetType
  targetId     String
  targetUserId String?
  reason       String
  details      String?
  createdAt    DateTime   @default(now())

  reporter   User  @relation("UserReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUser User? @relation("UserReportTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
}

model TravelerSimilarity {
  id               String   @id @default(cuid())
  userId           String
  travelerId       String
  matchScore       Int
  relevanceReason  String
  updatedAt        DateTime @updatedAt

  user     User @relation("TravelerScoreOwner", fields: [userId], references: [id], onDelete: Cascade)
  traveler User @relation("TravelerScoreMatch", fields: [travelerId], references: [id], onDelete: Cascade)

  @@unique([userId, travelerId])
}

model Moment {
  id             String         @id @default(cuid())
  userId         String
  placeId        String
  visitedAt      DateTime
  caption        String
  rating         Int
  ratingLabel    MomentRatingLabel @default(LIKED)
  budgetLevel    String
  visitType      VisitType
  timeOfDay      TimeOfDay
  privacy        Visibility    @default(PUBLIC)
  wouldRevisit   RevisitIntent
  vibeTags       String[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  place          Place          @relation(fields: [placeId], references: [id], onDelete: Cascade)
  media          MomentMedia[]
  comments       Comment[]
  vibins         Vibin[]
  collectionMoments CollectionMoment[]
  decisionCheckinContext DecisionCheckinContext?
  chatMessageAttachments ChatMessageAttachment[]
  feedPost       FeedPost?
}

model FeedPost {
  id             String     @id @default(cuid())
  userId         String
  placeId        String
  sourceMomentId String?    @unique
  imageUrl       String
  thumbnailUrl   String?
  caption        String
  ratingLabel    MomentRatingLabel?
  threeWordReview String?
  privacy        Visibility @default(PUBLIC)
  visitedAt      DateTime
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  place          Place      @relation(fields: [placeId], references: [id], onDelete: Cascade)
  sourceMoment   Moment?    @relation(fields: [sourceMomentId], references: [id], onDelete: SetNull)

  @@index([userId, visitedAt])
  @@index([placeId, visitedAt])
  @@index([privacy, visitedAt])
}

model DecisionSession {
  id            String   @id @default(cuid())
  userId        String?
  cityKey       String
  cityLabel     String
  intentId      String
  entryMode     String
  status        String
  chosenPlaceId String?
  userLatitude  Float?
  userLongitude Float?
  swapCount     Int      @default(0)
  skipCount     Int      @default(0)
  startedAt     DateTime @default(now())
  endedAt       DateTime?
  expiresAt     DateTime?
  metadataJson  Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  options       DecisionSessionOption[]
  events        DecisionSessionEvent[]
  saves         DecisionSave[]
  checkinContext DecisionCheckinContext?

  @@index([userId, createdAt])
  @@index([cityKey, createdAt])
  @@index([status, createdAt])
}

model DecisionSessionOption {
  id             String   @id @default(cuid())
  sessionId      String
  placeId        String
  optionRank     Int
  sourceType     String
  scoreTotal     Float?
  scoreBreakdown Json?
  reasonLabel    String?
  isSelected     Boolean  @default(false)
  isSkipped      Boolean  @default(false)
  isVisible      Boolean  @default(true)
  createdAt      DateTime @default(now())

  session        DecisionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  place          Place           @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([sessionId, optionRank])
  @@unique([sessionId, placeId])
  @@index([placeId])
}

model DecisionSessionEvent {
  id           String   @id @default(cuid())
  sessionId    String
  userId       String?
  placeId      String?
  eventType    String
  eventValue   String?
  eventPayload Json?
  createdAt    DateTime @default(now())

  session      DecisionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  place        Place?          @relation(fields: [placeId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@index([userId, createdAt])
  @@index([placeId, createdAt])
  @@index([eventType, createdAt])
}

model DecisionSave {
  id         String   @id @default(cuid())
  userId      String
  sessionId   String
  placeId     String
  status      String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  session     DecisionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  place       Place           @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([expiresAt])
}

model DecisionCheckinContext {
  id             String   @id @default(cuid())
  sessionId      String   @unique
  momentId       String   @unique
  userId         String
  placeId        String
  intentId       String?
  ratingLabel    String
  threeWordReview String?
  unlockFeed     Boolean  @default(true)
  createdAt      DateTime @default(now())

  session        DecisionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  moment         Moment          @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  place          Place           @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([placeId, createdAt])
}

model DecisionFeedUnlock {
  id            String   @id @default(cuid())
  userId        String
  unlockDate    DateTime
  sourceMomentId String
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, unlockDate])
  @@index([expiresAt])
}

model ExperimentAssignment {
  id            String   @id @default(cuid())
  userId        String
  experimentKey String
  variant       String
  assignedAt    DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, experimentKey])
}

model MomentMedia {
  id           String   @id @default(cuid())
  momentId      String
  mediaType     String
  url           String
  thumbnailUrl  String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  moment Moment @relation(fields: [momentId], references: [id], onDelete: Cascade)
}

model Collection {
  id          String             @id @default(cuid())
  userId      String
  title       String
  description String?
  coverImageUrl String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  places        CollectionPlace[]
  moments       CollectionMoment[]
}

model CollectionPlace {
  id           String   @id @default(cuid())
  collectionId String
  placeId      String
  sortOrder    Int      @default(0)

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  place      Place      @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([collectionId, placeId])
}

model CollectionMoment {
  id           String   @id @default(cuid())
  collectionId String
  momentId     String
  sortOrder    Int      @default(0)

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  moment     Moment     @relation(fields: [momentId], references: [id], onDelete: Cascade)

  @@unique([collectionId, momentId])
}

model Comment {
  id            String     @id @default(cuid())
  userId        String
  momentId      String?
  targetType    TargetType
  targetId      String
  body          String
  createdAt     DateTime   @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  moment Moment? @relation(fields: [momentId], references: [id], onDelete: SetNull)
}

model Vibin {
  id             String     @id @default(cuid())
  senderUserId   String
  receiverUserId String?
  momentId       String?
  targetType     TargetType
  targetId       String
  createdAt      DateTime   @default(now())

  sender   User   @relation("VibinSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  receiver User?  @relation("VibinReceiver", fields: [receiverUserId], references: [id], onDelete: SetNull)
  moment   Moment? @relation(fields: [momentId], references: [id], onDelete: SetNull)
}

model Share {
  id         String     @id @default(cuid())
  userId      String
  targetType  TargetType
  targetId    String
  channel     String?
  createdAt   DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id              String           @id @default(cuid())
  userId          String
  actorUserId     String?
  type            NotificationType
  targetType      TargetType?
  targetId        String?
  title           String
  body            String
  readAt          DateTime?
  createdAt       DateTime         @default(now())

  user      User  @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actorUser User? @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
}
