generator client {
  provider = "prisma-client-js"
  output   = "../../generated/prisma-v2-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_V2")
}

enum UserStatus {
  PENDING_PROFILE
  ACTIVE
  SUSPENDED
}

enum OnboardingStep {
  WELCOME
  INVITE_CONFIRMED
  PHONE_VERIFICATION
  PROFILE
  LOCATION_PERMISSION
  CONTACTS_PERMISSION
  FRIENDS
  FIRST_PLACE
  INVITE_SHARE
  COMPLETED
}

enum OtpPurpose {
  SIGN_UP
  SIGN_IN
}

enum OtpProvider {
  VONAGE_VERIFY
}

enum OtpRequestStatus {
  PENDING
  VERIFIED
  FAILED
  EXPIRED
  CANCELLED
}

enum TargetType {
  PROFILE
  MOMENT
  PLACE
  PLACE_VISIT
  COLLECTION
}

enum InviteCodeStatus {
  ACTIVE
  PAUSED
  EXHAUSTED
}

enum NotificationType {
  FOLLOW
  COMMENT
  VIBIN
  INVITE_REDEEMED
}

enum MomentVisibility {
  PUBLIC
  FRIENDS
  PRIVATE
}

model User {
  id                  String            @id @default(cuid())
  phoneNumberE164     String            @unique
  displayName         String?
  username            String?           @unique
  avatarUrl           String?
  bio                 String?
  cityLabel           String?
  cityLatitude        Float?
  cityLongitude       Float?
  citySource          String?
  nearbyDetectionMonthKey String?
  nearbyDetectionCount Int              @default(0)
  status              UserStatus        @default(PENDING_PROFILE)
  onboardingCompleted Boolean           @default(false)
  lastLoginAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  sessions            Session[]
  ownedInviteCode     InviteCode?
  inviteRedemption    InviteRedemption?
  onboardingState     UserOnboardingState?
  moments             Moment[]
  preferences         UserPreference?
  accountSettings     UserAccountSettings?
  privacySettings     UserPrivacySettings?
  bookmarks           Bookmark[]
  dismissedPlaces     DismissedPlace[]
  collections         Collection[]
  following           Follow[]          @relation("V2FollowSource")
  followers           Follow[]          @relation("V2FollowTarget")
  blocksGiven         UserBlock[]       @relation("V2UserBlockSource")
  blocksReceived      UserBlock[]       @relation("V2UserBlockTarget")
  reportsGiven        UserReport[]      @relation("V2UserReportReporter")
  reportsReceived     UserReport[]      @relation("V2UserReportTargetUser")
  notificationPrefs   UserNotificationSettings?
  pushDevices         UserPushDevice[]
  comments            Comment[]
  sentVibins          Vibin[]           @relation("V2VibinSender")
  receivedVibins      Vibin[]           @relation("V2VibinReceiver")
  notifications       Notification[]    @relation("V2NotificationRecipient")
  sentNotifications   Notification[]    @relation("V2NotificationActor")
}

model Session {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  lastSeenAt  DateTime  @default(now())
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model OtpRequest {
  id                String     @id @default(cuid())
  phoneNumberE164   String
  purpose           OtpPurpose
  provider          OtpProvider
  providerRequestId String     @unique
  status            OtpRequestStatus @default(PENDING)
  expiresAt         DateTime
  consumedAt        DateTime?
  lastAttemptAt     DateTime?
  attemptCount      Int        @default(0)
  resendCount       Int        @default(0)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([phoneNumberE164, purpose, createdAt])
  @@index([status, expiresAt])
  @@index([expiresAt])
}

model InviteCode {
  id              String             @id @default(cuid())
  ownerUserId     String             @unique
  code            String             @unique
  label           String?
  status          InviteCodeStatus   @default(ACTIVE)
  maxRedemptions  Int?
  redeemedCount   Int                @default(0)
  expiresAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  owner           User               @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  redemptions     InviteRedemption[]

  @@index([status, expiresAt])
}

model InviteRedemption {
  id                   String      @id @default(cuid())
  inviteCodeId         String
  userId               String      @unique
  phoneNumberE164      String
  redeemedAt           DateTime    @default(now())
  createdAt            DateTime    @default(now())

  inviteCode           InviteCode  @relation(fields: [inviteCodeId], references: [id], onDelete: Restrict)
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([inviteCodeId, redeemedAt])
  @@index([phoneNumberE164, redeemedAt])
}

model WaitlistEntry {
  id              String    @id @default(cuid())
  phoneNumberE164 String    @unique
  source          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model UserOnboardingState {
  id                     String         @id @default(cuid())
  userId                 String         @unique
  currentStep            OnboardingStep @default(WELCOME)
  completedSteps         String[]       @default([])
  skippedSteps           String[]       @default([])
  inviteCodeValidated    Boolean        @default(false)
  inviteCodeValidatedAt  DateTime?
  phoneVerifiedAt        DateTime?
  profileCompletedAt     DateTime?
  locationDecisionAt     DateTime?
  contactsDecisionAt     DateTime?
  firstPlaceLoggedAt     DateTime?
  inviteShareSeenAt      DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  user                   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Place {
  id                         String    @id @default(cuid())
  googlePlaceId              String?   @unique
  name                       String
  address                    String?
  city                       String?
  country                    String?
  neighborhood               String?
  category                   String
  shortFormattedAddress      String?
  googleTypes                String[]  @default([])
  googlePrimaryType          String?
  googlePrimaryTypeDisplayName String?
  latitude                   Float?
  longitude                  Float?
  rating                     Float?
  userRatingCount            Int?
  priceLevel                 Int?
  openingHours               String[]  @default([])
  currentOpeningHours        String[]  @default([])
  servesBreakfast            Boolean?
  servesLunch                Boolean?
  servesDinner               Boolean?
  servesBeer                 Boolean?
  servesWine                 Boolean?
  servesBrunch               Boolean?
  servesDessert              Boolean?
  servesCoffee               Boolean?
  servesCocktails            Boolean?
  goodForGroups              Boolean?
  goodForWatchingSports      Boolean?
  outdoorSeating             Boolean?
  mapsUrl                    String?
  websiteUri                 String?
  primaryImageUrl            String?
  lastGoogleFetchedAt        DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  moments                    Moment[]
  bookmarks                  Bookmark[]
  dismissedByUsers           DismissedPlace[]
  collectionPlaces           CollectionPlace[]
}

model UserPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique
  selectedInterests   String[] @default([])
  selectedVibe        String?
  onboardingCompleted Boolean  @default(false)
  skippedPreferences  Boolean  @default(false)
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserAccountSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPrivacySettings {
  id                String           @id @default(cuid())
  userId            String           @unique
  profileVisibility MomentVisibility @default(PUBLIC)
  momentVisibility  MomentVisibility @default(PUBLIC)
  updatedAt         DateTime         @updatedAt

  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  placeId   String
  source    String?
  expiresAt DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
  @@index([expiresAt])
}

model DismissedPlace {
  id        String   @id @default(cuid())
  userId    String
  placeId   String
  reason    String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
}

model Collection {
  id           String            @id @default(cuid())
  userId       String
  title        String
  description  String?
  coverImageUrl String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  places       CollectionPlace[]
}

model CollectionPlace {
  id           String     @id @default(cuid())
  collectionId String
  placeId      String
  sortOrder    Int        @default(0)

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  place        Place      @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([collectionId, placeId])
}

model Follow {
  id            String   @id @default(cuid())
  sourceUserId  String
  targetUserId  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sourceUser    User     @relation("V2FollowSource", fields: [sourceUserId], references: [id], onDelete: Cascade)
  targetUser    User     @relation("V2FollowTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([sourceUserId, targetUserId])
  @@index([sourceUserId, createdAt])
  @@index([targetUserId, createdAt])
}

model UserBlock {
  id            String   @id @default(cuid())
  sourceUserId  String
  targetUserId  String
  reason        String?
  createdAt     DateTime @default(now())

  sourceUser    User     @relation("V2UserBlockSource", fields: [sourceUserId], references: [id], onDelete: Cascade)
  targetUser    User     @relation("V2UserBlockTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([sourceUserId, targetUserId])
  @@index([sourceUserId, createdAt])
  @@index([targetUserId, createdAt])
}

model UserReport {
  id            String     @id @default(cuid())
  reporterId    String
  targetType    TargetType
  targetId      String
  targetUserId  String?
  reason        String
  details       String?
  createdAt     DateTime   @default(now())

  reporter      User       @relation("V2UserReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUser    User?      @relation("V2UserReportTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([reporterId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([targetUserId, createdAt])
}

model UserNotificationSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  pushEnabled           Boolean  @default(true)
  emailEnabled          Boolean  @default(true)
  recommendationEnabled Boolean  @default(true)
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPushDevice {
  id          String   @id @default(cuid())
  userId      String
  fcmToken    String   @unique
  platform    String
  appVersion  String?
  isActive    Boolean  @default(true)
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model Moment {
  id                       String    @id @default(cuid())
  userId                   String
  placeId                  String
  placeName                String
  placeLocation            String
  placeAddress             String?
  placeNeighborhood        String?
  placeCategory            String?
  placeGooglePlaceId       String?
  autocompleteSessionToken String?
  placeLatitude            Float?
  placeLongitude           Float?
  visitedAt                DateTime
  caption                  String
  uploadedMedia            String[]  @default([])
  rating                   Int?
  ratingLabel              String?
  wouldRevisit             String?
  visibility               MomentVisibility @default(PUBLIC)
  vibeTags                 String[]  @default([])
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  placeRecord              Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  comments                 Comment[]
  vibins                   Vibin[]

  @@index([userId, visitedAt])
  @@index([placeGooglePlaceId])
}

model Comment {
  id         String     @id @default(cuid())
  userId     String
  momentId   String?
  parentCommentId String?
  targetType TargetType
  targetId   String
  body       String
  createdAt  DateTime   @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  moment     Moment?    @relation(fields: [momentId], references: [id], onDelete: SetNull)
  parentComment Comment? @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies      Comment[] @relation("CommentReplies")

  @@index([targetType, targetId, createdAt])
  @@index([userId, createdAt])
  @@index([momentId])
  @@index([parentCommentId, createdAt])
}

model Vibin {
  id             String     @id @default(cuid())
  senderUserId   String
  receiverUserId String?
  momentId       String?
  targetType     TargetType
  targetId       String
  createdAt      DateTime   @default(now())

  sender         User       @relation("V2VibinSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  receiver       User?      @relation("V2VibinReceiver", fields: [receiverUserId], references: [id], onDelete: SetNull)
  moment         Moment?    @relation(fields: [momentId], references: [id], onDelete: SetNull)

  @@unique([senderUserId, targetType, targetId])
  @@index([targetType, targetId, createdAt])
  @@index([receiverUserId, createdAt])
  @@index([momentId])
}

model Notification {
  id          String            @id @default(cuid())
  userId      String
  actorUserId String?
  type        NotificationType
  targetType  TargetType?
  targetId    String?
  title       String
  body        String
  readAt      DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user        User              @relation("V2NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actorUser   User?             @relation("V2NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, readAt, createdAt])
  @@index([actorUserId, createdAt])
  @@index([targetType, targetId, createdAt])
}
