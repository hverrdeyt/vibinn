# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
API_ORIGIN="https://api.vibinn.club"
VITE_API_BASE_URL="https://api.vibinn.club"
VITE_MIXPANEL_TOKEN="YOUR_MIXPANEL_PROJECT_TOKEN"
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# DATABASE_URL: PostgreSQL connection string for Prisma.
DATABASE_URL="postgresql://postgres@localhost:5432/vibecheck_travel?schema=public"

# DATABASE_URL_V2: PostgreSQL connection string for the isolated v2 auth/user database.
DATABASE_URL_V2="postgresql://postgres@localhost:5432/vibecheck_travel_v2?schema=public"

# GOOGLE_MAPS_API_KEY: Optional for Google Places autocomplete on add/edit moment.
# If omitted, the app falls back to local sample place suggestions.
GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# GOOGLE_CLIENT_ID / VITE_GOOGLE_CLIENT_ID: Required for real Google sign-in.
# Use the same OAuth client ID value in both env vars.
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
VITE_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"

# TICKETMASTER_API_KEY: Optional for live concert and festival discovery.
# If omitted, event discovery endpoints will return an empty list.
TICKETMASTER_API_KEY="YOUR_TICKETMASTER_API_KEY"

# OPENAI_API_KEY: Optional for AI place enrichment.
# If omitted, editorial AI fields remain empty and the app stays factual-only.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_MODEL="gpt-5-mini"

# Vonage Verify: Required for v2 phone verification with OTP.
# Keep the fixed staging code only in staging env files. Do not set it in production.
VONAGE_API_KEY="YOUR_VONAGE_API_KEY"
VONAGE_API_SECRET="YOUR_VONAGE_API_SECRET"
VONAGE_VERIFY_BRAND="Vibinn"
VONAGE_VERIFY_CODE_LENGTH="6"
VONAGE_VERIFY_PIN_EXPIRY_SECONDS="300"
VONAGE_VERIFY_WORKFLOW_ID="1"
V2_STAGING_FIXED_OTP_CODE="1234"
APP_REVIEW_MODE_ENABLED="false"
APP_REVIEW_PHONE="+16172345678"
APP_REVIEW_OTP_CODE="1247"
V2_SESSION_TTL_MS="2592000000"

# Cloudflare R2: Optional for real media upload storage.
# If omitted, the app falls back to local uploads in development.
R2_ACCOUNT_ID="YOUR_R2_ACCOUNT_ID"
R2_BUCKET_NAME="YOUR_R2_BUCKET_NAME"
R2_ACCESS_KEY_ID="YOUR_R2_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="YOUR_R2_SECRET_ACCESS_KEY"
R2_ENDPOINT="https://YOUR_R2_ACCOUNT_ID.r2.cloudflarestorage.com"
R2_PUBLIC_URL=""
