{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:server": "tsx server/index.ts",
    "start:server": "node --import tsx server/index.ts",
    "build": "vite build",
    "build:app": "npm run build && npx cap sync",
    "build:server": "tsc --noEmit",
    "cap:sync": "npx cap sync",
    "ios:open": "npx cap open ios",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "places:backfill-google-photos": "tsx scripts/backfill-google-place-photos.ts",
    "places:backfill-google-price-ranges": "tsx scripts/backfill-google-place-price-ranges.ts",
    "places:backfill-google-detail-fields": "tsx scripts/backfill-google-place-detail-fields.ts",
    "places:acquire-google-text-search": "tsx scripts/acquire-google-text-search-places.ts",
    "ai:regenerate-place-enrichment": "tsx scripts/regenerate-place-enrichment.ts",
    "ai:retry-place-enrichment-failures": "tsx scripts/retry-place-enrichment-failures.ts",
    "ai:enrich-place-traits": "tsx scripts/enrich-place-trait-profiles.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.3.0",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/keyboard": "^8.0.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@google/genai": "^1.29.0",
    "@prisma/client": "^6.7.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^0.546.0",
    "mixpanel-browser": "^2.77.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "prisma": "^6.7.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "prisma": {
    "seed": "npm run prisma:seed"
  }
