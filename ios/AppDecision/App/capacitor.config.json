{
	"appId": "club.vibinn.app",
	"appName": "Vibinn",
	"webDir": "dist",
	"backgroundColor": "#09090b",
	"ios": {
		"contentInset": "automatic",
		"scrollEnabled": true,
		"allowsLinkPreview": false
	},
	"plugins": {
		"SplashScreen": {
			"launchAutoHide": true,
			"backgroundColor": "#09090b",
			"showSpinner": false
		},
		"StatusBar": {
			"style": "dark",
			"backgroundColor": "#09090b"
		},
		"Keyboard": {
			"resize": "body",
			"resizeOnFullScreen": true
		}
	},
	"packageClassList": [
		"AppPlugin",
		"CAPBrowserPlugin",
		"GeolocationPlugin",
		"HapticsPlugin",
		"KeyboardPlugin",
		"SharePlugin",
		"SplashScreenPlugin",
		"StatusBarPlugin"
	]
}
